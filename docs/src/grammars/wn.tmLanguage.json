{
  "id": "wn",
  "name": "wn",
  "scopeName": "source.wn",
  "aliases": ["cl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#literals" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "match": "//.*$",
      "name": "comment.line.double-slash.wn"
    },
    "strings": {
      "name": "string.quoted.wn",
      "begin": "[\"']",
      "end": "[\"']",
      "patterns": [{
        "match": "\\\\[ntr\\\\\"']",
        "name": "constant.character.escape.wn"
      }]
    },
    "numbers": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.wn"
    },
    "keywords": {
      "match": "\\b(wea|duro|pega|cachai|si|no|mientras|para|en|ojo|cago|devolver|cortala|sigue)\\b",
      "name": "keyword.control.wn"
    },
    "builtins": {
      "match": "\\b(altiro|largo|cachar|pregunta)\\b",
      "name": "support.function.builtin.wn"
    },
    "literals": {
      "match": "\\b(verdad|falso|nada)\\b",
      "name": "constant.language.wn"
    },
    "operators": {
      "match": "\\b(y|o)\\b|[+\\-*/%=<>!]=?|==|!=",
      "name": "keyword.operator.wn"
    },
    "identifiers": {
      "match": "[a-zA-Z_][a-zA-Z0-9_]*",
      "name": "variable.other.wn"
    }
  }
}